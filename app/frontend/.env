# Copy to .env.local (Vite convention) or .env and adjust.
#   cp .env.example .env.local

# Backend origin used by the SPA for API calls (see src/lib/config.ts).
# Local dev: matches Vite proxy target (backend on port 8001).
VITE_API_BASE_URL=http://127.0.0.1:8001

# Vite dev proxy target for /api/* calls (see vite.config.ts).
VITE_PROXY_TARGET=http://127.0.0.1:8001

# Dev server port (optional; default 3000 in vite.config.ts)
# VITE_PORT=3000

