# Copy to .env and adjust. Required for startup:
#   cp .env.example .env

# --- Required ---
# Async SQLAlchemy URL (examples below). Used by core/database.py.
# SQLite (local dev):
DATABASE_URL=sqlite+aiosqlite:///./app.db
database_url=sqlite+aiosqlite:///./app.db
# Postgres (example):
# DATABASE_URL=sqlite+aiosqlite:///./app.db
# database_url=sqlite+aiosqlite:///./app.db

# --- Server ---
PORT=8001
# ENVIRONMENT=dev

# --- Public API base URL (optional) ---
# Returned by GET /api/config as API_BASE_URL so the SPA can call the backend.
# Defaults to settings.backend_url (e.g. http://127.0.0.1:8001) if unset.
# VITE_API_BASE_URL=http://127.0.0.1:8001
# PYTHON_BACKEND_URL=http://127.0.0.1:8001

# --- Skip startup hooks (optional) ---
# MGX_IGNORE_INIT_DB=1
# MGX_IGNORE_INIT_DATA=1

# --- Admin / OIDC (only if you use those features) ---
# JWT_SECRET_KEY=
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# ADMIN_USER_ID=
# ADMIN_USER_EMAIL=
